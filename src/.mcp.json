{
    "mcpServers": {
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{API_KEY}"
            }
        },
        "sequential-thinking": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
        },
        "db-view-mcp": {
            "command": "npx",
            "args": ["-y", "@conte777/db-view-mcp", "--config", "/Users/conte/.db-mcp-config.json"]
        }
    }
}
