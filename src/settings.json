{
  "env": {
    "CLAUDE_CODE_NEW_INIT": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Skill",
      "mcp__sequential-thinking",
      "mcp__claude_ai_Context7",
      "mcp__db-view-mcp__list_databases",
      "mcp__db-view-mcp__query",
      "mcp__db-view-mcp__schema",
      "mcp__db-view-mcp__performance",
      "Bash(git worktree:*)",
      "Bash(git fetch:*)",
      "mcp__gitlab__list_merge_requests",
      "mcp__gitlab__get_merge_request",
      "mcp__gitlab__get_merge_request_diffs",
      "mcp__gitlab__list_merge_request_diffs",
      "mcp__gitlab__get_branch_diffs",
      "mcp__gitlab__list_merge_request_versions",
      "mcp__gitlab__get_merge_request_version",
      "mcp__gitlab__get_merge_request_conflicts",
      "mcp__gitlab__get_merge_request_approval_state",
      "mcp__gitlab__get_merge_request_notes",
      "mcp__gitlab__get_merge_request_note",
      "mcp__gitlab__mr_discussions",
      "mcp__gitlab__get_draft_note",
      "mcp__gitlab__list_draft_notes",
      "mcp__plugin_Notion_notion__notion-search",
      "mcp__claude_ai_Context7__resolve-library-id",
      "mcp__claude_ai_Context7__query-docs",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-query-database-view",
      "mcp__db-view-mcp__list_tables",
      "mcp__db-view-mcp__describe_table",
      "mcp__grafana__query_loki_stats",
      "mcp__grafana__query_loki_patterns",
      "mcp__grafana__query_loki_logs",
      "mcp__plugin_Notion_notion__notion-query-database-view",
      "mcp__plugin_Notion_notion__notion-fetch",
      "Bash(uv run *)",
      "mcp__grafana__search_dashboards",
      "mcp__grafana__list_datasources",
      "mcp__grafana__get_dashboard_panel_queries",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(Remove-Item:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(go get:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(kubectl delete:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/commit/scripts/collect-git-context.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/service-context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/lint-project.sh",
            "timeout": 150
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/commit/scripts/collect-git-context.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/format-and-lint.sh",
            "timeout": 40
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ralph-skills@ralph-marketplace": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ralph-marketplace": {
      "source": {
        "source": "github",
        "repo": "snarktank/ralph"
      }
    }
  },
  "language": "Russian",
  "alwaysThinkingEnabled": true,
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "plan"
}
