{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8787",
    "CLAUDE_CODE_NEW_INIT": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "LSP",
      "Agent",
      "Workflow",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "Skill",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "CronCreate",
      "CronDelete",
      "CronList",
      "ScheduleWakeup",
      "Monitor",
      "PushNotification",
      "AskUserQuestion",
      "WebSearch",
      "WebFetch",
      "DesignSync",
      "RemoteTrigger",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "mcp__context7__*",
      "mcp__verify__*",
      "mcp__headroom__*",
      "mcp__gitnexus__*",
      "mcp__grafana__*",
      "mcp__kubernetes__*",
      "mcp__db-view-mcp__*",
      "mcp__gitlab__*",
      "mcp__youtube-vision__*",
      "mcp__git__*"
    ],
    "deny": [],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(Remove-Item:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(kubectl delete:*)",
      "mcp__db-view-mcp__execute",
      "mcp__db-view-mcp__transaction",
      "mcp__gitlab__create_*",
      "mcp__gitlab__update_*",
      "mcp__gitlab__delete_*",
      "mcp__gitlab__merge_*",
      "mcp__gitlab__approve_*",
      "mcp__gitlab__unapprove_*",
      "mcp__gitlab__publish_*",
      "mcp__gitlab__bulk_publish_*",
      "mcp__gitlab__resolve_*",
      "mcp__grafana__create_*",
      "mcp__grafana__update_*",
      "mcp__grafana__add_*",
      "mcp__grafana__install_*",
      "mcp__grafana__alerting_manage_rules",
      "mcp__grafana__grafana_api_request"
    ],
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "deniedMcpServers": [],
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/Adrafinil.app/Contents/Helpers/adrafinil release $CLAUDE_CODE_SESSION_ID --tool claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/format-and-lint.sh",
            "timeout": 40
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Checking GitNexus index freshness..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/conte/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bash-tool-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/edit-write-autoapprove.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/service-context.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/conte/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/Adrafinil.app/Contents/Helpers/adrafinil release $CLAUDE_CODE_SESSION_ID --tool claude-code"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "code-reviewer",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/lint-project.sh",
            "timeout": 150
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/Adrafinil.app/Contents/Helpers/adrafinil acquire --tool claude-code --subagent"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/Adrafinil.app/Contents/Helpers/adrafinil release --tool claude-code --subagent"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/git-hook.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/review-task-fetch.sh",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/fix-cicd-fetch.sh",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/Adrafinil.app/Contents/Helpers/adrafinil acquire $CLAUDE_CODE_SESSION_ID --tool claude-code"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "head"
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline.sh\""
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "headroom@headroom-marketplace": true,
    "ponytail@ponytail": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "headroom-marketplace": {
      "source": {
        "source": "github",
        "repo": "chopratejas/headroom"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "language": "Russian",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "disableAutoMode": "disable",
  "autoCompactEnabled": true,
  "switchModelsOnFlag": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "voiceEnabled": true
}